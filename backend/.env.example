# Backend environment variables. Copy to .env for local development.
# In Docker/production, set these as real environment variables (do not bake secrets into the image).

# development | production
NODE_ENV=development

# Port the API listens on. Vercel/most platforms set this for you.
PORT=3001

# Comma-separated list of allowed CORS origins for this client's frontend(s).
# Example: https://app.restaurant-a.com,https://staging.restaurant-a.com
# If unset in production, falls back to the legacy grovyn.in/netlify defaults — always set this per client.
CORS_ORIGIN=http://localhost:5173

# HMAC secret used to sign stateless session tokens. Required in production; must be unique per client.
SESSION_SECRET=demo-secret-change-in-production

# Demo login password (used by the built-in email/password demo auth). Change or disable per client.
AUTH_DEMO_PASSWORD=grovyn@123
# Set to false to disable the demo password login entirely for a client's production deployment.
AUTH_DEMO_ENABLED=true

# Identifier reported by GET /api/v1/health and /health. Useful for multi-client observability.
SERVICE_NAME=grovyn-autopilot
