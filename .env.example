# Cloud Kitchen — root environment reference
#
# This repo has two deployable services, each with its own env file:
#   backend/.env.example   (API)
#   frontend/.env.example  (web app)
#
# This file is a consolidated overview for the deployment platform / docker-compose.
# Copy the two files above to `.env` in their respective folders for local development,
# or set these same keys as environment variables in your deployment platform.

# ---- Backend ----
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://your-frontend-domain.example.com
SESSION_SECRET=change-me-to-a-long-random-value
AUTH_DEMO_PASSWORD=grovyn@123
AUTH_DEMO_ENABLED=true
SERVICE_NAME=grovyn-autopilot

# ---- Frontend ----
VITE_API_BASE_URL=https://your-backend-domain.example.com
VITE_BRAND_NAME=Grovyn Autopilot
VITE_BRAND_SHORT_NAME=Autopilot
VITE_BRAND_LOGO_URL=
VITE_BRAND_FAVICON_URL=
VITE_BRAND_PRIMARY_COLOR=221 83% 53%
VITE_BRAND_SECONDARY_COLOR=210 40% 96%
VITE_SUPPORT_EMAIL=
VITE_SUPPORT_PHONE=
VITE_COMPANY_ADDRESS=
VITE_SHOW_DEMO_CREDENTIALS=true
