# Frontend environment variables. Copy to .env for local development.
# All VITE_* values are baked into the build by default. The same built image can also
# read these at container runtime via public/runtime-config.js — see deployment/README.md.

# API base URL (origin only; no trailing slash).
# Development: leave empty to use the Vite proxy to http://localhost:3001.
# For local dev, start the backend first: cd backend && npm run dev
# Production: set to your deployed backend, e.g. https://api.your-client.example.com
# VITE_API_BASE_URL=

# ---- Branding (per-client) ----
# Product/company name shown in the topbar, page title, and copy throughout the UI.
VITE_BRAND_NAME=Grovyn Autopilot
# Short form used in compact UI copy.
VITE_BRAND_SHORT_NAME=Autopilot
# Client logo / favicon URLs. Leave empty to use the default Grovyn branding.
VITE_BRAND_LOGO_URL=
VITE_BRAND_FAVICON_URL=
# Theme colors as HSL triplets ("H S% L%"), matching the CSS custom property format in index.css.
VITE_BRAND_PRIMARY_COLOR=221 83% 53%
VITE_BRAND_SECONDARY_COLOR=210 40% 96%
# Support contact info shown in the UI (optional).
VITE_SUPPORT_EMAIL=
VITE_SUPPORT_PHONE=
VITE_COMPANY_ADDRESS=
# Show the demo credentials hint on the sign-in screen. Set to false for real client deployments.
VITE_SHOW_DEMO_CREDENTIALS=true
